source "https://rubygems.org"

# Matches the gem set GitHub Pages builds with, so local == production.
gem "github-pages", group: :jekyll_plugins

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end

# Ruby 3+ no longer bundles a web server for `jekyll serve`.
gem "webrick", "~> 1.8"
